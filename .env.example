CORS_ORIGINS=
DAILY_FREE_GRANT=
ANON_DAILY_CHATS=
ANON_MESSAGES_PER_CHAT=
SIGNEDUP_DAILY_CHATS=
SIGNEDUP_MESSAGES_PER_CHAT=

# MongoDB (self-hosted). In Compose this is injected automatically; for native
# dev point it at your local mongo / atlas-free cluster.
# Uses the root user per project decision (no separate app user).
MONGODB_URI=
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
MONGO_INITDB_DATABASE=
# MongoDB Knowledge Service (no key needed). Override only if the endpoint moves.
KS_BASE_URL=
KS_ORIGIN=
KS_REQUEST_ORIGIN=

AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Single shared admin password (no registration, no users table).
ADMIN_PASSWORD=
# HMAC secret used to sign the admin session JWT (cookie). The FastAPI backend
# verifies the same token with the same secret. Can be reused as AUTH_SECRET.
ADMIN_SECRET=
AUTH_SECRET=

# HMAC secret shared between the frontend gateway and the FastAPI backend.
# The gateway signs every user-id assertion with this; the backend trusts
# X-Auth-User-Id ONLY when X-Gateway-Sig verifies. Without it, signed-in
# users degrade to anonymous (fail-safe, not fail-open).
# MUST be identical on frontend and backend. MUST be a strong random value
# in production (e.g. `openssl rand -hex 32`).
# Rotation: changing the secret causes ~60s of degraded service (signed-in
# users briefly downgrade to anonymous and need to refresh). No data loss,
# and no deploy order avoids this with a single secret.
GATEWAY_HMAC_SECRET=
