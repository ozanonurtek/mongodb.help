# ──────────────────────────────────────────────
# mongodb.help, Production Environment
# Copy to deploy/swarm/.env on the server
# ──────────────────────────────────────────────

# ── Domains ──
DOMAIN=
LEADS_DOMAIN=
AUTH_URL=

# ── CORS (comma-separated origins allowed to call the backend) ──
# Backend reads this directly. Keep aligned with the public-facing origins.
CORS_ORIGINS=

# ── Chat limits (override only if you want different defaults) ──
DAILY_FREE_GRANT=
ANON_DAILY_CHATS=
ANON_MESSAGES_PER_CHAT=
SIGNEDUP_DAILY_CHATS=
SIGNEDUP_MESSAGES_PER_CHAT=

# ── MongoDB ──
# MONGO_ROOT_PASSWORD must match the value used to create the docker secret
# (`docker secret create mongo_password -`). It is interpolated into the URI
# the app services use; the `mongo` container itself reads it from
# /run/secrets/mongo_password.
MONGO_ROOT_PASSWORD=
MONGODB_URI=mongodb://{user}:{pass}@mongo:27017/mongodbhelp?authSource=admin

# ── Auth.js (frontend) ──
# 32-byte hex session-signing secret. Generate: openssl rand -hex 32
AUTH_SECRET=

# OAuth providers, create these in each provider's developer console with
# the canonical redirect URI: https://mongodb.help/api/auth/callback/<provider>
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── Admin dashboard (leads.mongodb.help), single-password auth ──
# 64-hex password token. Generate: openssl rand -hex 32
ADMIN_PASSWORD=
# HMAC secret used to sign the admin session JWT. Reuse AUTH_SECRET or
# generate a separate one: openssl rand -hex 32
ADMIN_SECRET=

# ── MongoDB Knowledge Service (optional overrides) ──
KS_BASE_URL=
KS_ORIGIN=
KS_REQUEST_ORIGIN=

# HMAC secret shared with the backend (see backend service above).
# The gateway signs each X-Auth-User-Id assertion with this; the
# backend verifies. MUST match the backend value exactly.
GATEWAY_HMAC_SECRET=